function saveFollowup(e, id) {
  e.preventDefault();
  const form = e.target;
  if (rteIsEmpty(form, 'content')) { toast('иѓЈе°ЂеЖЩж≤ЯйАЪеЖЕеЃє', 'error'); return false; }
  const data = Object.fromEntries(new FormData(form).entries());
  data.content = rteGetValue(form, 'content');
  if (id) Object.assign(DB.followups.find(x => x.id === id), data);
  else DB.followups.push({ id: uid(), createdAt: new Date().toISOString(), done: false, ...data });
  try {
    saveDB();
  } catch (err) {
    toast('дњЭе≠Ше§±иі•пЉЪе≠ШеВ®з©ЇйЧідЄНиґ≥пЉМиѓЈеИ†йЩ§йГ®еИЖеЫЊзЙЗ', 'error');
    return false;
  }
  closeModal(); renderNav(); render(); toast('еЈ≤дњЭе≠Ш', 'success'); return false;
}

function deleteFollowup(id) {
  if (!confirm('з°ЃеЃЪеИ†йЩ§пЉЯ')) return;
  DB.followups = DB.followups.filter(x => x.id !== id);
  saveDB(); renderNav(); renderFollowups(); toast('еЈ≤еИ†йЩ§');
}

