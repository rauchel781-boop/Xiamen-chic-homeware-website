function starsHtml(n) {
  n = Number(n) || 0;
  let html = '<span class="stars">';
  for (let i = 1; i <= 5; i++) {
    html += i <= n ? 'вШЕ' : '<span class="stars-empty">вШЕ</span>';
  }
