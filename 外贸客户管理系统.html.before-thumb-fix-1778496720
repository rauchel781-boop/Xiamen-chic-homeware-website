<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>外贸业务管理系统</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", "Segoe UI", sans-serif;
  background: #f4f6f9; color: #2c3e50; font-size: 13px;
  height: 100vh; overflow: hidden;
}
.app { display: flex; height: 100vh; }

/* ===== Sidebar ===== */
.sidebar {
  width: 200px; background: #1f2937; color: #fff;
  flex-shrink: 0; display: flex; flex-direction: column;
}
.logo {
  padding: 18px 18px; font-size: 15px; font-weight: 600;
  border-bottom: 1px solid #374151; letter-spacing: 1px;
}
.logo .sub { font-size: 10px; color: #9ca3af; font-weight: normal; margin-top: 4px; letter-spacing: 0; }
.nav { flex: 1; padding: 8px 0; overflow-y: auto; }
.nav-item {
  padding: 9px 18px; cursor: pointer; display: flex;
  align-items: center; gap: 10px; color: #d1d5db;
  border-left: 3px solid transparent; transition: all 0.15s;
  font-size: 13px;
}
.nav-item:hover { background: #2a3340; color: #fff; }
.nav-item.active { background: #374151; color: #fff; border-left-color: #4a90e2; }
.nav-icon { width: 14px; text-align: center; font-size: 13px; }
.nav-badge {
  margin-left: auto; background: #ef4444; color: #fff;
  font-size: 10px; padding: 1px 6px; border-radius: 9px;
}
.sidebar-footer {
  padding: 12px 18px; border-top: 1px solid #374151;
  font-size: 10px; color: #9ca3af;
}

/* ===== Main ===== */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.topbar {
  background: #fff; padding: 12px 22px;
  border-bottom: 1px solid #e3e8ef;
  display: flex; align-items: center; justify-content: space-between;
}
.page-title { font-size: 17px; font-weight: 600; }
.topbar-actions { display: flex; gap: 8px; }
.tabs {
  background: #fff; padding: 0 22px; border-bottom: 1px solid #e3e8ef;
  display: flex; gap: 4px;
}
.tab {
  padding: 11px 14px; cursor: pointer; font-size: 13px; color: #6b7280;
  border-bottom: 2px solid transparent; margin-bottom: -1px;
}
.tab:hover { color: #2c3e50; }
.tab.active { color: #4a90e2; border-bottom-color: #4a90e2; font-weight: 500; }
.content { flex: 1; overflow-y: auto; padding: 18px 22px; }

/* ===== Buttons ===== */
.btn {
  padding: 6px 12px; border: 1px solid #d1d5db; background: #fff;
  border-radius: 4px; cursor: pointer; font-size: 12px; color: #374151;
  transition: all 0.15s; white-space: nowrap; font-family: inherit;
}
.btn:hover { background: #f3f4f6; border-color: #9ca3af; }
.btn-primary { background: #4a90e2; color: #fff; border-color: #4a90e2; }
.btn-primary:hover { background: #3a7fce; border-color: #3a7fce; }
.btn-success { background: #10b981; color: #fff; border-color: #10b981; }
.btn-success:hover { background: #059669; border-color: #059669; }
.btn-danger { color: #ef4444; }
.btn-danger:hover { background: #fef2f2; border-color: #ef4444; }
.btn-sm { padding: 3px 9px; font-size: 11px; }
.btn-link {
  background: none; border: none; color: #4a90e2; cursor: pointer;
  padding: 3px 6px; font-size: 12px; font-family: inherit;
}
.btn-link:hover { text-decoration: underline; }
.btn-link.danger { color: #ef4444; }

/* ===== Stats ===== */
.stats-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px; margin-bottom: 16px;
}
.stat-card {
  background: #fff; padding: 16px 18px; border-radius: 6px;
  border: 1px solid #e3e8ef;
}
.stat-label { font-size: 11px; color: #6b7280; margin-bottom: 4px; }
.stat-value { font-size: 22px; font-weight: 600; color: #2c3e50; }
.stat-value.green { color: #10b981; }
.stat-value.orange { color: #f59e0b; }
.stat-value.red { color: #ef4444; }
.stat-value.blue { color: #4a90e2; }
.stat-sub { font-size: 10px; color: #6b7280; margin-top: 3px; }
.stat-card.alert { border-color: #fecaca; background: #fef2f2; }

.dashboard-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;
}
.panel { background: #fff; border-radius: 6px; border: 1px solid #e3e8ef; }
.panel-header {
  padding: 12px 16px; border-bottom: 1px solid #e3e8ef;
  font-weight: 600; font-size: 13px;
  display: flex; justify-content: space-between; align-items: center;
}
.panel-body { padding: 12px 16px; max-height: 360px; overflow-y: auto; }
.panel-body.no-pad { padding: 0; }

/* ===== Table ===== */
.table-wrap {
  background: #fff; border-radius: 6px; border: 1px solid #e3e8ef; overflow: hidden;
}
.table-toolbar {
  padding: 10px 12px; display: flex; gap: 8px;
  align-items: center; border-bottom: 1px solid #e3e8ef; flex-wrap: wrap;
}
.search-box {
  flex: 1; min-width: 200px; padding: 6px 10px;
  border: 1px solid #d1d5db; border-radius: 4px; font-size: 12px;
  font-family: inherit;
}
.search-box:focus { outline: none; border-color: #4a90e2; }

.tbl-scroll { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; }
th, td {
  text-align: left; padding: 9px 12px;
  border-bottom: 1px solid #edf0f4; font-size: 12px;
  vertical-align: middle;
}
th {
  background: #f8fafb; color: #6b7280; font-weight: 600;
  font-size: 11px; white-space: nowrap;
}
tbody tr:hover { background: #fafbfc; }
.empty {
  padding: 60px 20px; text-align: center;
  color: #9ca3af; font-size: 13px;
}

/* ===== Tags ===== */
.tag {
  display: inline-block; padding: 2px 8px;
  border-radius: 11px; font-size: 10px; font-weight: 500;
  white-space: nowrap;
}
.tag-blue   { background: #dbeafe; color: #1e40af; }
.tag-green  { background: #d1fae5; color: #065f46; }
.tag-orange { background: #fef3c7; color: #92400e; }
.tag-red    { background: #fee2e2; color: #991b1b; }
.tag-gray   { background: #e5e7eb; color: #374151; }
.tag-purple { background: #ede9fe; color: #5b21b6; }
.tag-pink   { background: #fce7f3; color: #9d174d; }
.tag-cyan   { background: #cffafe; color: #155e75; }

/* ===== Stars ===== */
.stars { color: #f59e0b; letter-spacing: 1px; font-size: 13px; }
.stars-empty { color: #d1d5db; }
.star-input { cursor: pointer; font-size: 18px; user-select: none; }

/* ===== Flag ===== */
.flag { font-size: 14px; margin-right: 4px; vertical-align: -1px; }

/* ===== Modal ===== */
.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4);
  display: none; align-items: center; justify-content: center; z-index: 100;
}
.modal-mask.show { display: flex; }
.modal {
  background: #fff; border-radius: 8px; width: 600px;
  max-width: 90vw; max-height: 90vh; display: flex; flex-direction: column;
}
.modal.modal-lg { width: 800px; }
.modal.modal-xl { width: 1000px; }
.modal-header {
  padding: 14px 20px; border-bottom: 1px solid #e3e8ef;
  display: flex; justify-content: space-between; align-items: center;
}
.modal-title { font-size: 15px; font-weight: 600; }
.modal-close {
  background: none; border: none; cursor: pointer;
  font-size: 22px; color: #9ca3af; line-height: 1;
}
.modal-body { padding: 18px 20px; overflow-y: auto; flex: 1; }
.modal-footer {
  padding: 12px 20px; border-top: 1px solid #e3e8ef;
  display: flex; justify-content: flex-end; gap: 8px;
}

/* ===== Form ===== */
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.form-grid.cols-1 { grid-template-columns: 1fr; }
.form-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field.full { grid-column: 1 / -1; }
.field label { font-size: 11px; color: #6b7280; font-weight: 500; }
.field label .req { color: #ef4444; }
.field input, .field select, .field textarea {
  padding: 7px 10px; border: 1px solid #d1d5db; border-radius: 4px;
  font-size: 12px; font-family: inherit; background: #fff;
}
.field input:focus, .field select:focus, .field textarea:focus {
  outline: none; border-color: #4a90e2;
}
.field textarea { resize: vertical; min-height: 70px; }

/* ===== Detail ===== */
.detail-grid { display: grid; grid-template-columns: 110px 1fr; gap: 8px 14px; margin-bottom: 14px; }
.detail-grid dt { color: #6b7280; font-size: 11px; }
.detail-grid dd { color: #2c3e50; font-size: 12px; }
.detail-section { border-top: 1px solid #e5e7eb; padding-top: 14px; margin-top: 14px; }
.detail-section-title { font-weight: 600; font-size: 13px; margin-bottom: 10px; }

/* ===== Timeline ===== */
.timeline { position: relative; padding-left: 22px; }
.timeline::before {
  content: ''; position: absolute; left: 7px; top: 5px; bottom: 5px;
  width: 2px; background: #e5e7eb;
}
.timeline-item { position: relative; padding-bottom: 14px; }
.timeline-dot {
  position: absolute; left: -22px; top: 4px; width: 16px; height: 16px;
  border-radius: 50%; background: #fff; border: 2px solid #4a90e2;
  font-size: 10px; text-align: center; line-height: 12px;
}
.timeline-dot.green { border-color: #10b981; }
.timeline-dot.orange { border-color: #f59e0b; }
.timeline-dot.purple { border-color: #8b5cf6; }
.timeline-dot.red { border-color: #ef4444; }
.timeline-dot.gray { border-color: #9ca3af; }
.timeline-meta { font-size: 11px; color: #9ca3af; margin-bottom: 3px; }
.timeline-title { font-weight: 500; font-size: 13px; margin-bottom: 3px; }
.timeline-content { font-size: 12px; color: #4b5563; line-height: 1.5; }

/* ===== Tag input ===== */
.tag-input-wrap {
  display: flex; flex-wrap: wrap; gap: 4px;
  padding: 5px; border: 1px solid #d1d5db; border-radius: 4px; min-height: 32px;
}
.tag-input-wrap input { border: none; outline: none; flex: 1; min-width: 80px; padding: 4px; font-size: 12px; }
.tag-chip {
  background: #e0e7ff; color: #3730a3;
  padding: 2px 7px; border-radius: 11px; font-size: 11px;
  display: flex; align-items: center; gap: 4px;
}
.tag-chip .x { cursor: pointer; opacity: 0.6; font-weight: bold; }
.tag-chip .x:hover { opacity: 1; }

/* ===== Product image ===== */
.product-thumb {
  width: 50px; height: 50px; object-fit: cover;
  border-radius: 4px; border: 1px solid #e5e7eb; background: #f3f4f6;
}
.product-thumb-large {
  width: 120px; height: 120px; object-fit: cover;
  border-radius: 6px; border: 1px solid #e5e7eb; background: #f3f4f6;
}
.image-uploader {
  width: 120px; height: 120px; border: 2px dashed #d1d5db;
  border-radius: 6px; cursor: pointer; display: flex;
  align-items: center; justify-content: center; color: #9ca3af;
  font-size: 11px; text-align: center;
}
.image-uploader:hover { border-color: #4a90e2; color: #4a90e2; }

/* ===== Category tree ===== */
.tree {
  background: #f8fafb; border-right: 1px solid #e3e8ef;
  width: 200px; padding: 10px 0; overflow-y: auto;
}
.tree-item {
  padding: 6px 14px; cursor: pointer; font-size: 12px;
  display: flex; align-items: center; gap: 6px;
}
.tree-item:hover { background: #e8eef5; }
.tree-item.active { background: #dbeafe; color: #1e40af; font-weight: 500; }
.tree-item .count { margin-left: auto; color: #9ca3af; font-size: 10px; }
.tree-actions { padding: 8px 14px; border-bottom: 1px solid #e3e8ef; display: flex; gap: 4px; }

.split { display: flex; height: 100%; }
.split-main { flex: 1; overflow: hidden; display: flex; flex-direction: column; }

/* ===== Quotation items ===== */
.qt-items { width: 100%; border-collapse: collapse; }
.qt-items th, .qt-items td { padding: 6px; font-size: 11px; border-bottom: 1px solid #e5e7eb; }
.qt-items input, .qt-items select { padding: 4px 6px; font-size: 11px; width: 100%; border: 1px solid #d1d5db; border-radius: 3px; }
.qt-items .num { text-align: right; }

/* ===== Misc ===== */
.warning-box {
  background: #fffbeb; border: 1px solid #fde68a; color: #92400e;
  padding: 10px 14px; border-radius: 4px; font-size: 12px; margin-bottom: 12px;
}
.info-box {
  background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af;
  padding: 10px 14px; border-radius: 4px; font-size: 12px; margin-bottom: 12px;
}
.toast {
  position: fixed; top: 22px; right: 22px; background: #1f2937; color: #fff;
  padding: 10px 16px; border-radius: 4px; font-size: 12px; z-index: 200;
  opacity: 0; transform: translateY(-10px); transition: all 0.25s; pointer-events: none;
}
.toast.show { opacity: 1; transform: translateY(0); }
.toast.success { background: #10b981; }
.toast.error { background: #ef4444; }

::-webkit-scrollbar { width: 7px; height: 7px; }
::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
::-webkit-scrollbar-track { background: transparent; }

.muted { color: #9ca3af; }
.text-right { text-align: right; }
.text-center { text-align: center; }
.no-wrap { white-space: nowrap; }
.code { font-family: ui-monospace, "Cascadia Code", Consolas, monospace; font-size: 11px; color: #6366f1; }
.click { cursor: pointer; }
.click:hover { color: #4a90e2; }
.bold { font-weight: 600; }
hr.div { border: 0; border-top: 1px solid #e5e7eb; margin: 12px 0; }

/* ===== 客户档案（类 Notion 块） ===== */
.dossier { display: flex; flex-direction: column; gap: 8px; }
.dossier-block {
  border: 1px solid #e5e7eb; border-radius: 6px; background: #fff;
  overflow: hidden; transition: border-color 0.15s;
}
.dossier-block:hover { border-color: #c7d2da; }
.dossier-block-head {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 10px; background: #fafbfc; border-bottom: 1px solid #eef0f3;
  cursor: pointer; user-select: none;
}
.dossier-block.collapsed .dossier-block-head { border-bottom: none; }
.dossier-block.collapsed .dossier-block-body { display: none; }
.dossier-caret {
  font-size: 10px; color: #9ca3af; width: 12px; display: inline-block;
  transition: transform 0.15s;
}
.dossier-block.collapsed .dossier-caret { transform: rotate(-90deg); }
.dossier-type-icon {
  width: 16px; text-align: center; font-size: 11px; color: #6b7280;
}
.dossier-title {
  flex: 1; font-weight: 500; font-size: 12.5px; color: #2c3e50;
  background: transparent; border: none; outline: none; padding: 2px 4px;
}
.dossier-title:focus { background: #fff; box-shadow: inset 0 0 0 1px #4a90e2; border-radius: 3px; }
.dossier-actions { display: flex; gap: 2px; opacity: 0.5; transition: opacity 0.15s; }
.dossier-block-head:hover .dossier-actions { opacity: 1; }
.dossier-actions button {
  background: transparent; border: none; cursor: pointer;
  padding: 2px 6px; font-size: 11px; color: #6b7280; border-radius: 3px;
}
.dossier-actions button:hover { background: #e5e7eb; color: #2c3e50; }
.dossier-actions button.danger:hover { background: #fee2e2; color: #dc2626; }
.dossier-block-body { padding: 10px 12px; font-size: 12.5px; line-height: 1.6; }
.dossier-text-view { color: #2c3e50; word-break: break-word; }
.dossier-text-view p { margin: 0 0 6px; }
.dossier-text-view p:last-child { margin-bottom: 0; }
.dossier-text-view ul, .dossier-text-view ol { margin: 4px 0 6px 22px; }
.dossier-text-view img { max-width: 100%; height: auto; border-radius: 3px; }
.dossier-text-edit {
  min-height: 64px; padding: 8px; border: 1px solid #d1d5db;
  border-radius: 4px; outline: none; font-size: 12.5px; line-height: 1.6;
}
.dossier-text-edit:focus { border-color: #4a90e2; box-shadow: 0 0 0 2px rgba(74,144,226,0.15); }
.dossier-toolbar {
  display: flex; gap: 2px; flex-wrap: wrap;
  margin-bottom: 6px; padding-bottom: 6px; border-bottom: 1px solid #eef0f3;
}
.dossier-toolbar button {
  background: #fff; border: 1px solid #e5e7eb; cursor: pointer;
  padding: 3px 8px; font-size: 11px; border-radius: 3px; color: #4b5563;
}
.dossier-toolbar button:hover { background: #f3f4f6; }
.dossier-image-wrap { text-align: center; }
.dossier-image-wrap img { max-width: 100%; max-height: 380px; border-radius: 4px; }
.dossier-image-caption { font-size: 11px; color: #6b7280; margin-top: 4px; font-style: italic; }
.dossier-image-empty {
  border: 2px dashed #d1d5db; border-radius: 6px; padding: 28px;
  text-align: center; color: #9ca3af; cursor: pointer;
}
.dossier-image-empty:hover { border-color: #4a90e2; color: #4a90e2; }
.dossier-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.dossier-table td {
  border: 1px solid #e5e7eb; padding: 4px 6px; min-width: 60px;
  vertical-align: top;
}
.dossier-table td:first-child { background: #fafbfc; font-weight: 500; }
.dossier-table input {
  width: 100%; border: none; outline: none; background: transparent;
  font-size: 12px; padding: 2px;
}
.dossier-table input:focus { background: #fff; box-shadow: inset 0 0 0 1px #4a90e2; }
.dossier-table-tools { display: flex; gap: 6px; margin-top: 6px; }
.dossier-table-tools button {
  background: #f3f4f6; border: 1px solid #e5e7eb; cursor: pointer;
  padding: 2px 8px; font-size: 11px; border-radius: 3px; color: #4b5563;
}
.dossier-table-tools button:hover { background: #e5e7eb; }
.dossier-add-bar {
  display: flex; gap: 6px; flex-wrap: wrap;
  margin-top: 10px; padding: 8px; background: #fafbfc;
  border: 1px dashed #d1d5db; border-radius: 6px;
}
.dossier-add-bar button {
  background: #fff; border: 1px solid #e5e7eb; cursor: pointer;
  padding: 4px 10px; font-size: 11.5px; border-radius: 3px; color: #4b5563;
}
.dossier-add-bar button:hover { background: #4a90e2; color: #fff; border-color: #4a90e2; }
.dossier-storage-info {
  font-size: 10.5px; color: #9ca3af; margin-left: auto; align-self: center;
}
.dossier-storage-info.warn { color: #f59e0b; }
.dossier-storage-info.danger { color: #ef4444; }
.dossier-empty {
  padding: 24px; text-align: center; color: #9ca3af;
  border: 1px dashed #e5e7eb; border-radius: 6px;
}

/* ===== 富文本编辑器 (RTE) ===== */
.rte-wrap { border: 1px solid #d1d5db; border-radius: 4px; overflow: hidden; background: #fff; }
.rte-wrap:focus-within { border-color: #4a90e2; box-shadow: 0 0 0 2px rgba(74,144,226,0.15); }
.rte-toolbar {
  display: flex; flex-wrap: wrap; gap: 2px;
  padding: 4px 6px; background: #fafbfc; border-bottom: 1px solid #eef0f3;
  align-items: center;
}
.rte-toolbar button {
  background: transparent; border: 1px solid transparent; cursor: pointer;
  padding: 3px 7px; font-size: 12px; border-radius: 3px; color: #4b5563;
  min-width: 22px; line-height: 1.3;
}
.rte-toolbar button:hover { background: #e5e7eb; border-color: #d1d5db; }
.rte-toolbar select {
  border: 1px solid #d1d5db; background: #fff; font-size: 11px;
  padding: 2px 4px; border-radius: 3px; cursor: pointer;
}
.rte-toolbar .sep { width: 1px; background: #e5e7eb; align-self: stretch; margin: 2px 4px; }
.rte-color-wrap {
  display: inline-flex; align-items: center; gap: 3px; padding: 2px 5px;
  font-size: 12px; color: #4b5563; border: 1px solid transparent; border-radius: 3px;
  cursor: pointer; position: relative;
}
.rte-color-wrap:hover { background: #e5e7eb; }
.rte-color-wrap input[type="color"] {
  width: 14px; height: 14px; border: none; padding: 0; cursor: pointer;
  background: transparent;
}
.rte-editor {
  padding: 8px 10px; outline: none; font-size: 13px; line-height: 1.6;
  background: #fff; word-break: break-word; min-height: 120px;
  max-height: 420px; overflow-y: auto;
}
.rte-editor img {
  max-width: 100%; height: auto; border-radius: 3px; margin: 4px 0;
  display: inline-block;
}
.rte-editor p { margin: 0 0 6px; }
.rte-editor ul, .rte-editor ol { margin: 4px 0 6px 22px; }
.rte-editor:empty:before {
  content: attr(data-placeholder); color: #9ca3af;
  pointer-events: none;
}
.rte-hint { font-size: 10.5px; color: #9ca3af; padding: 3px 8px; background: #fafbfc; border-top: 1px solid #eef0f3; }
/* 时间轴里的富文本内容 */
.timeline-content img, .rte-readonly img {
  max-width: 280px; max-height: 200px; border-radius: 3px;
  vertical-align: middle; margin: 4px 0;
}
.rte-readonly { font-size: 12.5px; line-height: 1.6; word-break: break-word; }
.rte-readonly p { margin: 0 0 6px; }
.rte-readonly ul, .rte-readonly ol { margin: 4px 0 6px 22px; }

/* ===== 产品图拖放区 ===== */
.product-img-drop { outline: none; border-radius: 4px; transition: box-shadow 0.15s; }
